NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# (선택) NEXT_PUBLIC 없이 서버만 쓸 때 — Vercel에 위 두 개 대신 아래만 넣어도 서버 로그인은 동작할 수 있음
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here

# 선택: 로그인 화면 이메일 칸 기본값 (미입력 시에도 이 값으로 로그인 시도)
# Supabase Authentication → Users 에 동일 이메일 사용자가 있어야 합니다.
# NEXT_PUBLIC_KIOSK_EMAIL=본인이_만든_이메일
